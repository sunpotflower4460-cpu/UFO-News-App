            "value": "SkyTraceは、空で報告された事象を出典・証拠・不確実性とともに記録します。信じさせることも、否定することも目的にしません。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "SkyTrace records what's reported in the sky with its sources, evidence, and uncertainty. It exists neither to convince nor to debunk."
          }
        }
      }
    },
    "trust.learnMore": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "詳しい方針"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Detailed policies"
          }
        }
      }
    },
    "trust.stance.1": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「未解明」を「地球外起源」とは断定しません。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Unexplained\" is never equated with \"extraterrestrial.\""
          }
        }
      }
    },
    "trust.stance.2": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "既知現象との照合を先に行い、残った部分だけを未解明として示します。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Known causes are checked first; only what remains is marked unexplained."
          }
        }
      }
    },
    "trust.stance.3": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "単一の信ぴょう性スコアは使いません。証拠を複数の軸で示します。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No single credibility score — evidence is shown across several axes."
          }
        }
      }
    },
    "trust.stance.4": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AIは証拠を整理する編集助手であり、真実を宣言する権威ではありません。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AI is an editorial assistant that organizes evidence, not an authority that declares truth."
          }
        }
      }
    },
    "trust.stance.title": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "私たちの立場"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Our stance"
          }
        }
      }
    },
    "trust.status.note": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ステータスは「理解の状態」を表し、物体の正体を表しません。"
