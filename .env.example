# SkyTrace environment template. Copy to `.env` and fill in for local backend
# work (Phase 2+). The iOS app requires NONE of these for Phase 1 — it runs on
# fixtures and the local StoreKit configuration with no external credentials.
#
# Never commit real secrets. AI/DB/API keys are server-side only and are never
# embedded in the iOS app.

# --- Backend (Phase 2) ---
DATABASE_URL=postgresql+psycopg://skytrace:skytrace@localhost:5432/skytrace
REDIS_URL=redis://localhost:6379/0
API_BASE_URL=http://localhost:8000

# --- AI providers (Phase 5, server-side only) ---
# Leave blank to use the FakeLLMProvider.
LLM_PROVIDER=fake
LLM_API_KEY=

# --- Source providers (Phase 3, default disabled) ---
# Providers stay disabled until rights are approved in the Source Registry.
SOURCE_FIREBALL_ENABLED=false
SOURCE_SATELLITE_TLE_URL=

# --- App Store Server API (Phase 6, server-side verification) ---
APP_STORE_ISSUER_ID=
APP_STORE_KEY_ID=
APP_STORE_PRIVATE_KEY_PATH=
APP_STORE_BUNDLE_ID=com.example.skytrace
